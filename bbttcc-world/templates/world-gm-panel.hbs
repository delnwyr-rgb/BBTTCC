{{!-- bbttcc-world/templates/world-gm-panel.hbs --}}
<section class="bbttcc-world-gm-panel">
  <header style="margin-bottom:.5rem;">
    <div style="display:flex; justify-content:space-between; align-items:baseline; gap:.75rem;">
      <div>
        <div style="font-weight:700; font-size:1.4rem;">World State</div>
        <div class="bbttcc-muted" style="opacity:.85;">
          Signed in as <b data-bind="userName">{{userName}}</b>
          · Strategic Turn: <b data-bind="turn">{{state.turn}}</b>
        </div>
        <div class="bbttcc-muted" style="opacity:.75; font-size:.9rem;">
          Values shown are current world values. Edit as needed and click Apply. (Apply is GM-only, enforced in code.)
        </div>
      </div>
      <div style="display:flex; gap:.4rem; align-items:center;">
        <button type="button" class="button" data-action="refresh">Refresh</button>
      </div>
    </div>
  </header>

  <fieldset style="border:1px solid rgba(255,255,255,.12); border-radius:10px; padding:.6rem;">
    <legend style="padding:0 .35rem; opacity:.9;">Core</legend>
    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:.5rem;">
      <div>
        <label>Turn</label>
        <input type="number" name="turn" />
      </div>
      <div>
        <label>Darkness</label>
        <input type="number" name="darkness" min="0" max="100" step="1" />
      </div>
    </div>
    <div style="margin-top:.5rem;">
      <label>Pressure Mod</label>
      <input type="number" name="pressureMod" min="0" max="5" step="0.1" />
    </div>
  </fieldset>

  <fieldset style="border:1px solid rgba(255,255,255,.12); border-radius:10px; padding:.6rem; margin-top:.6rem;">
    <legend style="padding:0 .35rem; opacity:.9;">Time</legend>
    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:.5rem;">
      <div>
        <label>Epoch</label>
        <input type="number" name="time.epoch" />
      </div>
      <div>
        <label>Turn Length (TP)</label>
        <input type="number" name="time.turnLength" min="1" step="1" />
      </div>
    </div>
    <div style="margin-top:.5rem;">
      <label>Progress (Time Points)</label>
      <input type="number" name="time.progress" min="0" step="1" />
      <div class="bbttcc-muted" style="opacity:.75; margin-top:.15rem;">
        TP toward the next Strategic Turn:
        <b data-bind="timeProgress">{{timeProgress}}</b>/<b data-bind="timeTurnLength">{{timeTurnLength}}</b>
      </div>
    </div>
  </fieldset>

  <fieldset style="border:1px solid rgba(255,255,255,.12); border-radius:10px; padding:.6rem; margin-top:.6rem;">
    <legend style="padding:0 .35rem; opacity:.9;">Esoteric Influences</legend>

    <div style="display:flex; justify-content:space-between; align-items:baseline; gap:.75rem; flex-wrap:wrap;">
      <div class="bbttcc-muted" style="opacity:.85;" data-bind="esotericStatus">
        Loading esoteric influences...
      </div>

      <div style="display:flex; gap:.4rem; align-items:center;">
        <button type="button" class="button" data-action="esoteric-open">Open Correspondences</button>
        <button type="button" class="button" data-action="esoteric-whisper">Whisper Summary</button>
      </div>
    </div>

    <div style="margin-top:.45rem;" data-bind="esotericTable"></div>
  </fieldset>

  <fieldset style="border:1px solid rgba(255,255,255,.12); border-radius:10px; padding:.6rem; margin-top:.6rem;">
    <legend style="padding:0 .35rem; opacity:.9;">Locks</legend>
    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:.5rem;">
      <label style="display:flex; gap:.4rem; align-items:center;"><input type="checkbox" name="locks.turnAdvance" /> Lock Turn Advance</label>
      <label style="display:flex; gap:.4rem; align-items:center;"><input type="checkbox" name="locks.mutation" /> Lock Mutation</label>
      <label style="display:flex; gap:.4rem; align-items:center;"><input type="checkbox" name="locks.politics" /> Lock Politics</label>
      <label style="display:flex; gap:.4rem; align-items:center;"><input type="checkbox" name="locks.logistics" /> Lock Logistics</label>
    </div>
  </fieldset>

  <fieldset style="border:1px solid rgba(255,255,255,.12); border-radius:10px; padding:.6rem; margin-top:.6rem;">
    <legend style="padding:0 .35rem; opacity:.9;">Snapshots</legend>
    <div class="bbttcc-muted" style="opacity:.8; font-size:.9rem; margin-bottom:.35rem;">
      Save a snapshot before risky edits. Roll back restores world state + faction/hex flags (best-effort).
    </div>

    <div style="display:flex; gap:.5rem; flex-wrap:wrap; align-items:center;">
      <button type="button" class="button" data-action="snapshot-create">Save Snapshot</button>

      <label style="display:flex; flex-direction:column; gap:.2rem; min-width:280px; flex:1;">
        <span style="opacity:.85;">Saved Snapshots</span>
        <select name="snapshotId" style="width:100%;">
          <option value="">(none)</option>
        </select>
      </label>

      <div style="display:flex; gap:.4rem; flex-wrap:wrap; align-items:center;">
        <button type="button" class="button" data-action="snapshot-rollback">Rollback</button>
        <button type="button" class="button" data-action="snapshot-delete">Delete</button>
        <button type="button" class="button" data-action="snapshot-export">Export</button>
        <button type="button" class="button" data-action="snapshot-clear-all">Clear All</button>
      </div>
    </div>

    <div class="bbttcc-muted" style="opacity:.75; font-size:.85rem; margin-top:.35rem;">
      <span data-bind="snapshotCount">0</span> snapshots stored (max 20).
    </div>
  </fieldset>

  <fieldset style="border:1px solid rgba(255,255,255,.12); border-radius:10px; padding:.6rem; margin-top:.6rem;">
    <legend style="padding:0 .35rem; opacity:.9;">GM Note (audit)</legend>
    <textarea name="note" rows="3" style="width:100%;" placeholder="What are you changing, and why?">{{lastNote}}</textarea>
  </fieldset>

  <footer style="display:flex; justify-content:flex-end; gap:.5rem; margin-top:.75rem;">
    <button type="button" class="button" data-action="clear">Clear</button>
    <button type="button" class="button" data-action="close">Close</button>
    <button type="button" class="button" data-action="apply">Apply</button>
  </footer>
</section>
